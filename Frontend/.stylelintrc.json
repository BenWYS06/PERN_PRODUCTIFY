{
  "extends": ["stylelint-config-standard-scss"],
  "rules": {
    "scss/at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "plugin",
          "theme",
          "source",
          "utility",
          "variant",
          "custom-variant",
          "import"
        ]
      }
    ]
  }
}
